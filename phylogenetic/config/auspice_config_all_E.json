{
  "title": "Real-time tracking of Env gene in dengue virus evolution",
  "maintainers": [
   {"name": "Jennifer Chang", "url": "https://bedford.io/team/jennifer-chang/"},
   {"name": "Trevor Bedford", "url": "http://bedford.io/team/trevor-bedford/"}
  ],
  "build_url": "https://github.com/nextstrain/dengue",  
  "colorings": [
    {
      "key": "gt",
      "title": "Genotype",
      "type": "categorical"
    },
    {
      "key": "num_date",
      "title": "Date",
      "type": "continuous"
    },
    {
      "key": "country",
      "title": "Country",
      "type": "categorical"
    },
    {
      "key": "region",
      "title": "Region",
      "type": "categorical"
    },
    {
      "key": "nextclade_type",
      "title": "Serotype",
      "type": "categorical"
    }
  ],
  "geo_resolutions": [
    "country",
    "region"
  ],
  "display_defaults": {
    "map_triplicate": true,
    "color_by": "nextclade_type",
    "distance_measure": "div"
  },
  "filters": [
    "country",
    "region",
    "author"
  ]
}
